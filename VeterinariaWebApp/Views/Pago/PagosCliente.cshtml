@model IEnumerable<VeterinariaWebApp.Models.Pago.Pago>

@{
    ViewData["Title"] = "Mis Pagos";
    Layout = "~/Views/Shared/_LayoutCliente.cshtml";
}

<h1>Mis Pagos</h1>
<hr>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Pagos Registrados</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.IdPago)</th>
                        <th>@Html.DisplayNameFor(model => model.HoraPago)</th>
                        <th>@Html.DisplayNameFor(model => model.MontoPago)</th>
                        <th>@Html.DisplayNameFor(model => model.TipoPago)</th>
                        <th>@Html.DisplayNameFor(model => model.NombreCliente)</th>
                        <th>@Html.DisplayNameFor(model => model.CorreoCliente)</th>
                        <th>@Html.DisplayNameFor(model => model.EstadoPago)</th> <!-- Nueva columna -->
                        <th>ACCIONES</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@Html.DisplayFor(modelItem => item.IdPago)</td>
                            <td>@Html.DisplayFor(modelItem => item.HoraPago)</td>
                            <td>@Html.DisplayFor(modelItem => item.MontoPago)</td>
                            <td>@Html.DisplayFor(modelItem => item.TipoPago)</td>
                            <td>@Html.DisplayFor(modelItem => item.NombreCliente)</td>
                            <td>@Html.DisplayFor(modelItem => item.CorreoCliente)</td>
                            <td>
                                @if (item.EstadoPago == "Pendiente")
                                {
                                    <span class="badge bg-warning text-dark">Pendiente</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Realizado</span>
                                }
                            </td>
                            <td>
                                <a href="@Url.Action("DetallePago", "Pago", new { id = item.IdPago, origen = "PagosCliente" })" class="btn btn-info btn-sm me-2">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="@Url.Action("DetallePagoPDF", "Pago", new { id = item.IdPago })" class="btn btn-danger btn-sm me-2">
                                    <i class="fas fa-file-pdf"></i>
                                </a>
                                <!-- Botón de Eliminar (solo para pagos pendientes) -->
                                @if (item.EstadoPago == "Pendiente")
                                {
                                    <form asp-action="EliminarPago" asp-controller="Pago" asp-route-id="@item.IdPago" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-danger btn-sm btn-eliminar-pago"
                                                data-nombre="@item.NombreCliente">
                                            <i class="fas fa-archive"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.btn-eliminar-pago').forEach(btn => {
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                const form = this.closest('form');
                Swal.fire({
                    title: '¿Estás seguro?',
                    text: 'Esta acción no se puede deshacer.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#dc3545',
                    cancelButtonColor: '#94827F',
                    confirmButtonText: 'Sí, eliminar',
                    cancelButtonText: 'Cancelar',
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });
        });
    </script>
}