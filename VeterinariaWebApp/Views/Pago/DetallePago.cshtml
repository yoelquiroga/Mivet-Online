@model VeterinariaWebApp.Models.Pago.Pago

@{
    ViewData["Title"] = "Detalle de Pago";
    var recepcionistaId = Context.Session.GetInt32("RecepcionistaId");
    var clienteId = Context.Session.GetInt32("ClienteId");

    var origen = ViewBag.Origen as string;

    if (clienteId != null && clienteId != 0)
    {
        Layout = "~/Views/Shared/_LayoutCliente.cshtml";
    }
    else if (recepcionistaId != null && recepcionistaId != 0)
    {
        Layout = "~/Views/Shared/_LayoutRecepcionista.cshtml";
    }
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card detail-card">
                <div class="card-header detail-header-gradient py-4">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <div class="detail-avatar">
                                <i class="fas fa-money-bill-wave"></i>
                            </div>
                        </div>
                        <div class="col">
                            <h2 class="mb-1 fw-bold">Pago #@Model.IdPago</h2>
                            <p class="mb-0 opacity-75">
                                <i class="fas fa-user me-1"></i>@Model.NombreCliente
                            </p>
                        </div>
                        <div class="col-auto">
                            <span class="badge-header">
                                <i class="fas fa-circle me-1"></i>@Model.EstadoPago
                            </span>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="detail-info-card">
                                <div class="info-header">
                                    <i class="fas fa-hashtag"></i>
                                    <span>ID Pago</span>
                                </div>
                                <div class="info-body">
                                    @Model.IdPago
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-info-card">
                                <div class="info-header">
                                    <i class="fas fa-calendar-day"></i>
                                    <span>Fecha y Hora</span>
                                </div>
                                <div class="info-body">
                                    @Model.HoraPago.ToString("dd/MM/yyyy HH:mm")
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-info-card">
                                <div class="info-header">
                                    <i class="fas fa-hand-holding-usd"></i>
                                    <span>Monto</span>
                                </div>
                                <div class="info-body">
                                    S/ @Model.MontoPago.ToString("0.00")
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-info-card">
                                <div class="info-header">
                                    <i class="fas fa-credit-card"></i>
                                    <span>Tipo de Pago</span>
                                </div>
                                <div class="info-body">
                                    @Model.TipoPago
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-info-card">
                                <div class="info-header">
                                    <i class="fas fa-user"></i>
                                    <span>Cliente</span>
                                </div>
                                <div class="info-body">
                                    @Model.NombreCliente
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-info-card">
                                <div class="info-header">
                                    <i class="fas fa-envelope"></i>
                                    <span>Correo Electrónico</span>
                                </div>
                                <div class="info-body">
                                    @Model.CorreoCliente
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            @if (clienteId != null && clienteId != 0)
                            {
                                var accionCliente = string.IsNullOrEmpty(origen) ? "PagosCliente" : origen;
                                <a asp-controller="Pago" asp-action="@accionCliente"
                                   class="btn btn-outline-secondary">
                                    <i class="fas fa-arrow-left me-1"></i> Volver
                                </a>
                            }
                            else if (recepcionistaId != null && recepcionistaId != 0)
                            {
                                var accionRecep = string.IsNullOrEmpty(origen) ? "PagosPendientes" : origen;
                                <a asp-controller="Pago" asp-action="@accionRecep"
                                   class="btn btn-outline-secondary">
                                    <i class="fas fa-arrow-left me-1"></i> Volver
                                </a>
                            }
                        </div>
                        <div>
                            <a asp-action="DetallePagoPDF" asp-route-id="@Model.IdPago" class="btn btn-danger">
                                <i class="fas fa-file-pdf me-1"></i> Exportar PDF
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>