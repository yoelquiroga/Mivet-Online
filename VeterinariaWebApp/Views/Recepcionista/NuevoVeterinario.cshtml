@model VeterinariaWebApp.Models.Usuario.Veterinario.VeterinarioO

@{
    ViewData["Title"] = "Nuevo Veterinario";
    Layout = "~/Views/Shared/_LayoutRecepcionista.cshtml";
    var listaDocumentos = ViewBag.documentos as SelectList;
    var listaEspecialidad = ViewBag.especialidad as SelectList;
}

<div class="container-fluid">

    <div class="mb-3">
        <a asp-controller="Recepcionista" asp-action="listarVeterinarios" class="edit-back-link">
            <i class="fas fa-arrow-left"></i> Volver al listado
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">
            <div class="edit-form-card">
                <div class="card-header create-header-gradient py-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="icon-circle-create">
                            <i class="fas fa-user-md fa-lg"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold">Registrar Nuevo Veterinario</h5>
                            <small>Complete los datos del nuevo veterinario</small>
                        </div>
                    </div>
                </div>

                <div class="edit-form-body">
                    <form asp-action="NuevoVeterinario">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="edit-form-grid">
                            <div class="form-field-card">
                                <label asp-for="nom_usr" class="form-label">
                                    <i class="fas fa-user"></i> Nombres
                                </label>
                                <input asp-for="nom_usr" class="form-control" />
                                <span asp-validation-for="nom_usr" class="text-danger small"></span>
                            </div>

                            <div class="form-field-card">
                                <label asp-for="ape_usr" class="form-label">
                                    <i class="fas fa-user-tag"></i> Apellidos
                                </label>
                                <input asp-for="ape_usr" class="form-control" />
                                <span asp-validation-for="ape_usr" class="text-danger small"></span>
                            </div>

                            <div class="form-field-card">
                                <label asp-for="ide_doc" class="form-label">
                                    <i class="fas fa-file-alt"></i> Tipo Documento
                                </label>
                                @Html.DropDownListFor(model => model.ide_doc, listaDocumentos, new { @class = "form-select" })
                                <span asp-validation-for="ide_doc" class="text-danger small"></span>
                            </div>

                            <div class="form-field-card">
                                <label asp-for="num_doc" class="form-label">
                                    <i class="fas fa-id-card"></i> Número Documento
                                </label>
                                <input asp-for="num_doc" class="form-control" />
                                <span asp-validation-for="num_doc" class="text-danger small"></span>
                            </div>

                            <div class="form-field-card">
                                <label asp-for="fna_usr" class="form-label">
                                    <i class="fas fa-calendar-alt"></i> Fecha de Nacimiento
                                </label>
                                <input asp-for="fna_usr" class="form-control" />
                                <span asp-validation-for="fna_usr" class="text-danger small"></span>
                            </div>

                            <div class="form-field-card">
                                <label asp-for="ide_esp" class="form-label">
                                    <i class="fas fa-stethoscope"></i> Especialidad
                                </label>
                                @Html.DropDownListFor(model => model.ide_esp, listaEspecialidad, new { @class = "form-select" })
                                <span asp-validation-for="ide_esp" class="text-danger small"></span>
                            </div>

                            <div class="form-field-card">
                                <label asp-for="sue_vet" class="form-label">
                                    <i class="fas fa-dollar-sign"></i> Sueldo
                                </label>
                                <input asp-for="sue_vet" class="form-control" type="number" step="0.01" min="0.01" onkeypress="return (event.charCode >= 48 && event.charCode <= 57) || event.charCode === 46" />
                                <span asp-validation-for="sue_vet" class="text-danger small"></span>
                            </div>

                            <div class="form-field-card full-width">
                                <label asp-for="cor_usr" class="form-label">
                                    <i class="fas fa-envelope"></i> Correo Electrónico
                                </label>
                                <input asp-for="cor_usr" type="email" class="form-control" maxlength="100" minlength="8" />
                                <span asp-validation-for="cor_usr" class="text-danger small"></span>
                            </div>

                            <div class="form-field-card full-width">
                                <label asp-for="pwd_usr" class="form-label">
                                    <i class="fas fa-lock"></i> Contraseña
                                </label>
                                <input asp-for="pwd_usr" class="form-control" type="password" />
                                <span asp-validation-for="pwd_usr" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="edit-form-footer">
                            <a asp-controller="Recepcionista" asp-action="listarVeterinarios" class="btn-cancel-edit">
                                <i class="fas fa-times me-1"></i> Cancelar
                            </a>
                            <button type="submit" class="btn-create-gradient">
                                <i class="fas fa-user-check me-1"></i> Registrar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
