@model VeterinariaWebApp.Models.Cita.Cita

@{
    ViewData["Title"] = "Detalle de Cita";
    var veterinarioId = Context.Session.GetInt32("VeterinarioId");
    var clienteId = Context.Session.GetInt32("ClienteId");

    if (clienteId != null && clienteId != 0)
    {
        Layout = "~/Views/Shared/_LayoutCliente.cshtml";
    }
    else if (veterinarioId != null && veterinarioId != 0)
    {
        Layout = "~/Views/Shared/_LayoutVeterinario.cshtml";
    }
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card detail-card">
                <div class="card-header detail-header-gradient py-4">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <div class="detail-avatar">
                                <i class="fas fa-calendar-check"></i>
                            </div>
                        </div>
                        <div class="col">
                            <h2 class="mb-1 fw-bold">Cita #@Model.IdCita</h2>
                            <p class="mb-0 opacity-75">
                                <i class="fas fa-paw me-1"></i>@Model.NombreMascota
                            </p>
                        </div>
                        <div class="col-auto">
                            <span class="badge-header">
                                <i class="fas fa-circle me-1"></i>@Model.EstadoDescripcion
                            </span>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="detail-info-card">
                                <div class="info-header">
                                    <i class="fas fa-hashtag"></i>
                                    <span>ID Cita</span>
                                </div>
                                <div class="info-body">
                                    @Model.IdCita
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-info-card">
                                <div class="info-header">
                                    <i class="far fa-calendar-alt"></i>
                                    <span>Fecha y Hora</span>
                                </div>
                                <div class="info-body">
                                    @Model.CalendarioCita.ToString("dd/MM/yyyy HH:mm")
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-info-card">
                                <div class="info-header">
                                    <i class="fas fa-door-open"></i>
                                    <span>Consultorio</span>
                                </div>
                                <div class="info-body">
                                    @Model.Consultorio
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-info-card">
                                <div class="info-header">
                                    <i class="fas fa-user-md"></i>
                                    <span>Veterinario</span>
                                </div>
                                <div class="info-body">
                                    Dr(a). @Model.NombreVeterinario
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-info-card">
                                <div class="info-header">
                                    <i class="fas fa-paw"></i>
                                    <span>Mascota</span>
                                </div>
                                <div class="info-body">
                                    @Model.NombreMascota
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-info-card">
                                <div class="info-header">
                                    <i class="fas fa-money-bill-wave"></i>
                                    <span>Monto</span>
                                </div>
                                <div class="info-body">
                                    S/ @Model.MontoPago.ToString("0.00")
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            @if (clienteId != null && clienteId != 0)
                            {
                                <a asp-controller="Cliente" asp-action="listaCitaPorCliente"
                                   class="btn btn-outline-secondary">
                                    <i class="fas fa-arrow-left me-1"></i> Volver
                                </a>
                            }
                            else if (veterinarioId != null && veterinarioId != 0)
                            {
                                <a asp-controller="Veterinario" asp-action="listaCitaPorVeterinarios" asp-route-ide_usr="@veterinarioId"
                                   class="btn btn-outline-secondary">
                                    <i class="fas fa-arrow-left me-1"></i> Volver
                                </a>
                            }
                        </div>
                        <div>
                            <a asp-action="GenerarDetalleCitaPDF" asp-route-id="@Model.IdCita" class="btn btn-danger">
                                <i class="fas fa-file-pdf me-1"></i> Exportar PDF
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
