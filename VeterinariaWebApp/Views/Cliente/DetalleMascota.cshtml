@model VeterinariaWebApp.Models.Mascota.Mascota

@{
    ViewData["Title"] = "Detalle de Mascota";
    Layout = "~/Views/Shared/_LayoutCliente.cshtml";
    var clienteId = Context.Session.GetInt32("ClienteId");
}

<div class="container-fluid">
    <!-- Page Heading -->
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="fas fa-paw text-info me-2"></i> Detalle de Mascota
        </h1>
        <a asp-action="listaMascotasPorCliente" class="btn btn-secondary btn-sm">
            <i class="fas fa-arrow-left me-1"></i> Volver al listado
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card detail-card">
                <!-- Header con degradado -->
                <div class="card-header detail-header-gradient py-4">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <div class="detail-avatar">
                                @switch (Model.Especie?.ToLower())
                                {
                                    case "perro":
                                        <span>🐕</span>
                                        break;
                                    case "gato":
                                        <span>🐱</span>
                                        break;
                                    case "ave":
                                        <span>🐦</span>
                                        break;
                                    case "conejo":
                                        <span>🐰</span>
                                        break;
                                    case "hamster":
                                        <span>🐹</span>
                                        break;
                                    case "pez":
                                        <span>🐠</span>
                                        break;
                                    case "tortuga":
                                        <span>🐢</span>
                                        break;
                                    default:
                                        <span>🐾</span>
                                        break;
                                }
                            </div>
                        </div>
                        <div class="col">
                            <h2 class="mb-1 fw-bold">@Model.Nombre</h2>
                            <p class="mb-0 opacity-75">
                                <i class="fas fa-hashtag me-1"></i>ID: @Model.IdMascota
                            </p>
                        </div>
                        <div class="col-auto">
                            <span class="badge-header">
                                <i class="fas fa-heart me-1"></i>@Model.Edad
                            </span>
                        </div>
                    </div>
                </div>
 
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="detail-info-card">
                                <div class="info-header">
                                    <i class="fas fa-paw"></i>
                                    <span>Especie</span>
                                </div>
                                <div class="info-body">
                                    @Model.Especie
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-info-card">
                                <div class="info-header">
                                    <i class="fas fa-dna"></i>
                                    <span>Raza</span>
                                </div>
                                <div class="info-body">
                                    @(string.IsNullOrEmpty(Model.Raza) ? "No especificada" : Model.Raza)
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-info-card">
                                <div class="info-header">
                                    <i class="fas fa-birthday-cake"></i>
                                    <span>Fecha de Nacimiento</span>
                                </div>
                                <div class="info-body">
                                    @Model.FechaNacimiento.ToString("dd 'de' MMMM 'de' yyyy")
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-info-card">
                                <div class="info-header">
                                    <i class="fas fa-clock"></i>
                                    <span>Edad Actual</span>
                                </div>
                                <div class="info-body">
                                    @Model.Edad
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Información adicional -->
                    <div class="alert alert-light border-info mt-3">
                        <div class="d-flex align-items-start">
                            <i class="fas fa-info-circle text-info me-3 mt-1 fa-lg"></i>
                            <div>
                                <h6 class="fw-bold mb-1">Información de registro</h6>
                                <p class="mb-0 text-muted small">
                                    Esta mascota está registrada en el sistema MiVet Online. 
                                    Puede agendar citas médicas y llevar un historial de atenciones veterinarias.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer">
                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="listaMascotasPorCliente" 
                           class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-1"></i> Volver
                        </a>
                        <div>
                            <a asp-action="ActualizarMascota" asp-route-id="@Model.IdMascota" 
                               class="btn btn-warning text-white me-2">
                                <i class="fas fa-edit me-1"></i> Editar
                            </a>
                            <button type="button" class="btn btn-danger" id="btnEliminar" 
                                    data-id="@Model.IdMascota" data-nombre="@Model.Nombre">
                                <i class="fas fa-trash me-1"></i> Eliminar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.getElementById('btnEliminar').addEventListener('click', function () {
                const idMascota = this.getAttribute('data-id');
                const nombreMascota = this.getAttribute('data-nombre');

                Swal.fire({
                    title: '¿Eliminar mascota?',
                    html: `¿Estás seguro de que deseas eliminar a <strong>${nombreMascota}</strong>?<br><small class="text-muted">Esta acción no se puede deshacer.</small>`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#dc3545',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: '<i class="fas fa-trash me-1"></i> Sí, eliminar',
                    cancelButtonText: '<i class="fas fa-times me-1"></i> Cancelar',
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        fetch(`/Cliente/EliminarMascota?id=${idMascota}`, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: '¡Eliminado!',
                                    text: data.message,
                                    confirmButtonColor: '#28a745'
                                }).then(() => {
                                    window.location.href = '@Url.Action("listaMascotasPorCliente", "Cliente")';
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'No se puede eliminar',
                                    text: data.message,
                                    confirmButtonColor: '#28a745'
                                });
                            }
                        })
                        .catch(error => {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error',
                                text: 'Hubo un problema al eliminar la mascota.',
                                confirmButtonColor: '#28a745'
                            });
                        });
                    }
                });
            });
        });
    </script>
}

<style>
    .detail-avatar span {
        font-size: 2.5rem;
    }
</style>
