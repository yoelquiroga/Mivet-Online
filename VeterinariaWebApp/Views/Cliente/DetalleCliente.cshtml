
@model VeterinariaWebApp.Models.Usuario.Cliente.Cliente

@{
    ViewData["Title"] = "DetalleCliente";
    var recepcionistaId = Context.Session.GetInt32("RecepcionistaId");
    var medicoId = Context.Session.GetInt32("VeterinarioId");

    if (medicoId != null && medicoId != 0)
    {
        Layout = "~/Views/Shared/_LayoutVeterinario.cshtml";
    }
    else if (recepcionistaId != null && recepcionistaId != 0)
    {
        Layout = "~/Views/Shared/_LayoutRecepcionista.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_LayoutCliente.cshtml";
    }
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card detail-card">
                <div class="card-header detail-header-gradient py-4">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <div class="detail-avatar">
                                <i class="fas fa-user"></i>
                            </div>
                        </div>
                        <div class="col">
                            <h2 class="mb-1 fw-bold">@Model.NombreUsuario @Model.ApellidoUsuario</h2>
                            <p class="mb-0 opacity-75">
                                <i class="fas fa-hashtag me-1"></i>ID: @Model.IdCliente
                            </p>
                        </div>
                        <div class="col-auto">
                            <span class="badge-header">
                                <i class="fas fa-user-tag me-1"></i>@Model.Rol
                            </span>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="detail-info-card">
                                <div class="info-header">
                                    <i class="fas fa-id-card"></i>
                                    <span>ID Cliente</span>
                                </div>
                                <div class="info-body">
                                    @Model.IdCliente
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-info-card">
                                <div class="info-header">
                                    <i class="fas fa-user"></i>
                                    <span>Nombre</span>
                                </div>
                                <div class="info-body">
                                    @Model.NombreUsuario @Model.ApellidoUsuario
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-info-card">
                                <div class="info-header">
                                    <i class="fas fa-birthday-cake"></i>
                                    <span>Fecha de Nacimiento</span>
                                </div>
                                <div class="info-body">
                                    @Model.FechaNacimiento.ToString("dd/MM/yyyy")
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-info-card">
                                <div class="info-header">
                                    <i class="fas fa-address-card"></i>
                                    <span>Tipo Documento</span>
                                </div>
                                <div class="info-body">
                                    @Model.TipoDocumento
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-info-card">
                                <div class="info-header">
                                    <i class="fas fa-id-badge"></i>
                                    <span>Número Documento</span>
                                </div>
                                <div class="info-body">
                                    @Model.NumeroDocumento
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-info-card">
                                <div class="info-header">
                                    <i class="fas fa-user-tag"></i>
                                    <span>Rol</span>
                                </div>
                                <div class="info-body">
                                    @Model.Rol
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            @if (recepcionistaId != null && recepcionistaId != 0)
                            {
                                <a asp-controller="Recepcionista" asp-action="listarClientes"
                                   class="btn btn-outline-secondary">
                                    <i class="fas fa-arrow-left me-1"></i> Volver
                                </a>
                            }
                            else if (medicoId != null && medicoId != 0)
                            {
                                <a asp-controller="Veterinario" asp-action="listaCitaPorVeterinarios" asp-route-ide_usr="@medicoId"
                                   class="btn btn-outline-secondary">
                                    <i class="fas fa-arrow-left me-1"></i> Volver
                                </a>
                            }
                        </div>
                        <div>
                            <a asp-action="DetalleClientePDF" asp-route-id="@Model.IdCliente" class="btn btn-danger">
                                <i class="fas fa-file-pdf me-1"></i> Exportar PDF
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
